```gitignore
# ======================
# ENV FILES (CRITICAL)
# ======================
.env
.env.*
!.env.example

# ======================
# NODE MODULES
# ======================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ======================
# BUILD FILES
# ======================
dist/
build/
.next/
out/

# ======================
# LOG FILES
# ======================
logs/
*.log

# ======================
# OS FILES
# ======================
.DS_Store
Thumbs.db

# ======================
# EDITOR FILES
# ======================
.vscode/
.idea/
*.swp
*.swo

# ======================
# CACHE
# ======================
.cache/
.parcel-cache/

# ======================
# COVERAGE
# ======================
coverage/

# ======================
# TEMP FILES
# ======================
tmp/
temp/

# ======================
# UPLOADS (if any)
# ======================
uploads/
public/uploads/

# ======================
# DATABASE FILES
# ======================
*.sqlite
*.db

# ======================
# MISC
# ======================
*.pem
*.key
*.crt
```

